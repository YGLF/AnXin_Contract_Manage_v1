APP_NAME=安信合同管理系统
APP_VERSION=1.0.0

# MySQL 配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=rootroots
MYSQL_DATABASE=contract_manage

# JWT 安全配置
# 生产环境请务必修改为复杂的随机字符串（至少32位）
# 生成方法: openssl rand -base64 32
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 文件上传目录
UPLOAD_DIR=uploads

# 管理员账号配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin@123456
ADMIN_EMAIL=admin@example.com

# 审计管理员账号配置
AUDIT_ADMIN_USERNAME=auditadmin
AUDIT_ADMIN_PASSWORD=auditadmin@123456
AUDIT_ADMIN_EMAIL=audit@example.com


# 加密服务配置（可选）
# HSM密码机配置
# HSM_ENABLED=true
# HSM_ENDPOINT=http://hsm-server:8888
# HSM_APP_ID=your-app-id

# SM4对称加密配置
# SM4_ENABLED=true
# SM4_KEY=1234567890123456

# AES对称加密配置
# AES_ENABLED=true
# AES_KEY=12345678901234567890123456789012
